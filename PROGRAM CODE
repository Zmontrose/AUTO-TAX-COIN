use anchor_lang::prelude::*;
use anchor_spl::token::{
    self, Burn, Mint, MintTo, Token, TokenAccount, Transfer,
};

declare_id!("ReplaceWithYourProgramID");

#[program]
pub mod tax_token {
    use super::*;

    pub fn initialize(
        ctx: Context<Initialize>,
        tax_percent: u8,
        burn_percent: u8,
        initial_supply: u64,
    ) -> Result<()> {
        require!(tax_percent <= 100, ErrorCode::InvalidTax);
        require!(burn_percent <= tax_percent, ErrorCode::InvalidBurn);

        let config = &mut ctx.accounts.config;
        config.owner = *ctx.accounts.owner.key;
        config.mint = ctx.accounts.mint.key();
        config.treasury = ctx.accounts.treasury.key();
        config.tax_percent = tax_percent;
        config.burn_percent = burn_percent;

        let cpi_ctx = CpiContext::new(
            ctx.accounts.token_program.to_account_info(),
            MintTo {
                mint: ctx.accounts.mint.to_account_info(),
                to: ctx.accounts.owner_token_account.to_account_info(),
                authority: ctx.accounts.owner.to_account_info(),
            },
        );

        token::mint_to(cpi_ctx, initial_supply)?;

        Ok(())
    }

    pub fn transfer_with_tax(ctx: Context<TransferWithTax>, amount: u64) -> Result<()> {
        let config = &ctx.accounts.config;

        let tax_amount = amount
            .checked_mul(config.tax_percent as u64)
            .unwrap()
            .checked_div(100)
            .unwrap();

        let burn_amount = amount
            .checked_mul(config.burn_percent as u64)
            .unwrap()
            .checked_div(100)
            .unwrap();

        let treasury_amount = tax_amount.checked_sub(burn_amount).unwrap();
        let user_amount = amount.checked_sub(tax_amount).unwrap();

        // Transfer to recipient
        let transfer_ctx = CpiContext::new(
            ctx.accounts.token_program.to_account_info(),
            Transfer {
                from: ctx.accounts.from.to_account_info(),
                to: ctx.accounts.to.to_account_info(),
                authority: ctx.accounts.sender.to_account_info(),
            },
        );
        token::transfer(transfer_ctx, user_amount)?;

        // Transfer to treasury
        let treasury_ctx = CpiContext::new(
            ctx.accounts.token_program.to_account_info(),
            Transfer {
                from: ctx.accounts.from.to_account_info(),
                to: ctx.accounts.treasury_account.to_account_info(),
                authority: ctx.accounts.sender.to_account_info(),
            },
        );
        token::transfer(treasury_ctx, treasury_amount)?;

        // Burn
        let burn_ctx = CpiContext::new(
            ctx.accounts.token_program.to_account_info(),
            Burn {
                mint: ctx.accounts.mint.to_account_info(),
                from: ctx.accounts.from.to_account_info(),
                authority: ctx.accounts.sender.to_account_info(),
            },
        );
        token::burn(burn_ctx, burn_amount)?;

        Ok(())
    }
}

#[account]
pub struct TokenConfig {
    pub owner: Pubkey,
    pub mint: Pubkey,
    pub treasury: Pubkey,
    pub tax_percent: u8,
    pub burn_percent: u8,
}

#[derive(Accounts)]
pub struct Initialize<'info> {
    #[account(init, payer = owner, space = 8 + 32 + 32 + 32 + 1 + 1)]
    pub config: Account<'info, TokenConfig>,

    #[account(mut)]
    pub owner: Signer<'info>,

    #[account(mut)]
    pub mint: Account<'info, Mint>,

    #[account(mut)]
    pub owner_token_account: Account<'info, TokenAccount>,

    #[account(mut)]
    pub treasury: SystemAccount<'info>,

    pub token_program: Program<'info, Token>,
    pub system_program: Program<'info, System>,
}

#[derive(Accounts)]
pub struct TransferWithTax<'info> {
    pub config: Account<'info, TokenConfig>,

    #[account(mut)]
    pub sender: Signer<'info>,

    #[account(mut)]
    pub from: Account<'info, TokenAccount>,

    #[account(mut)]
    pub to: Account<'info, TokenAccount>,

    #[account(mut)]
    pub treasury_account: Account<'info, TokenAccount>,

    #[account(mut)]
    pub mint: Account<'info, Mint>,

    pub token_program: Program<'info, Token>,
}

#[error_code]
pub enum ErrorCode {
    #[msg("Invalid tax percentage")]
    InvalidTax,
    #[msg("Burn cannot exceed tax")]
    InvalidBurn,
}
